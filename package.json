{
  "name": "vite_react_shadcn_ts",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "frontend": "vite",
    "build": "vite build",
    "build:dev": "vite build --mode development",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:bun": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "setup": "bun install",
    "db:push": "supabase db push --linked --yes",
    "db:status": "supabase migration list --linked",
    "types:gen": "supabase gen types typescript --linked > src/integrations/supabase/types.ts",
    "functions:deploy": "supabase functions deploy --project-ref $(cat supabase/.temp/project-ref)",
    "backend": "echo 'Hosted Supabase is canonical. Use: bun run db:push. Optional local Docker: bun run win:stack:up'",
    "win:stack:up": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/stack-up.ps1",
    "win:stack:down": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/stack-down.ps1",
    "win:stack:env": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/stack-env.ps1",
    "win:db:reset": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/db-reset-wsl.ps1",
    "win:docker:engine": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/ensure-docker-wsl.ps1"
  },
  "packageManager": "bun@1.3.14",
  "dependencies": {
