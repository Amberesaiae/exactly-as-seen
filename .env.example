# LampFarms — Environment Variables
# Copy this file to .env.local and fill in the values
# Never commit .env.local to git
# Local stack guide: docs/BACKEND_LOCAL.md

# ── Supabase ──────────────────────────────────────────────────────────────────
# Local (after: npx supabase start):
# VITE_SUPABASE_URL=http://127.0.0.1:54321
# Hosted: https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_URL=http://127.0.0.1:54321

# Public anon / publishable key from `npx supabase status` or dashboard → Settings → API
# Either name works (client accepts both):
VITE_SUPABASE_ANON_KEY=your-anon-key-here
# VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key-here

# ── Push Notifications (optional) ────────────────────────────────────────────
# Generate: npx web-push generate-vapid-keys
VITE_VAPID_PUBLIC_KEY=

# ── App (optional) ───────────────────────────────────────────────────────────
VITE_DEFAULT_CURRENCY=GHS
