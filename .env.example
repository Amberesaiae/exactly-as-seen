# LampFarms — Environment Variables
# Copy this file to .env.local and fill in the values
# Never commit .env.local to git

# ── Supabase ──────────────────────────────────────────────────────────────────
# Your project URL from: https://app.supabase.com → Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co

# The public anon key from: https://app.supabase.com → Settings → API
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ── Push Notifications (optional) ────────────────────────────────────────────
# Generate a VAPID key pair with: npx web-push generate-vapid-keys
# Paste the *public* key here (the private key stays in your Supabase Edge Function env)
VITE_VAPID_PUBLIC_KEY=

# ── App (optional) ───────────────────────────────────────────────────────────
# Override the default currency symbol shown in the UI
VITE_DEFAULT_CURRENCY=GHS
